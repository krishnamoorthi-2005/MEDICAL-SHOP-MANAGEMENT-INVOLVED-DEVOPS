# Database
# LOCAL: mongodb://localhost:27017/pharmacy_system
# ATLAS: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/pharmacy_system?retryWrites=true&w=majority

# Server
PORT=5000
JWT_SECRET=change_this_secret

# ─── WhatsApp Stock Notifications ──────────────────────────────────────────────
WHATSAPP_NOTIFICATIONS_ENABLED=true
WHATSAPP_PHONE_NUMBER=919876543210           # Your phone number (country code + number, no + sign)
WHATSAPP_NOTIFY_CRON=0 9 * * *               # Daily at 9:00 AM (cron syntax)
TZ=Asia/Kolkata                              # Timezone for scheduler
